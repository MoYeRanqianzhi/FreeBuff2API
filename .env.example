# FreeBuff2API Configuration
# Copy this file to .env and fill in the values

# Required: FreeBuff API key (from ~/.config/manicode/credentials.json -> authToken)
FREEBUFF_API_KEY=

# FreeBuff backend URL
FREEBUFF_BASE_URL=https://codebuff.com

# Listen address
LISTEN_ADDR=:8080

# Optional: API key to protect this proxy (clients must send this as Bearer token)
API_KEY=

# Default model when client doesn't specify one
DEFAULT_MODEL=anthropic/claude-sonnet-4

# Cost mode: free, normal, max
COST_MODE=free

# Log level: debug, info, warn, error
LOG_LEVEL=info
